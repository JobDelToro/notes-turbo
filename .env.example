# ======================= Backend (Django / DRF) =======================
# Generate a key with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database — SQLite by default (leave empty). For Postgres / prod parity:
#   DATABASE_URL=postgres://notes:notes@localhost:5432/notes
DATABASE_URL=

# Frontend origin — used for CORS, CSRF trusted origins and cookie domain
FRONTEND_ORIGIN=http://localhost:3000

# JWT cookie auth (httpOnly access + refresh)
JWT_COOKIE_SECURE=False          # set True in production (HTTPS only)
JWT_COOKIE_SAMESITE=Lax          # use "None" (with JWT_COOKIE_SECURE=True) for cross-domain FE/API
JWT_ACCESS_TTL_MIN=15            # access-token lifetime (client silently refreshes on 401)
JWT_REFRESH_TTL_DAYS=7           # refresh-token lifetime

# Extra production hardening — only applied when DJANGO_DEBUG=False
DJANGO_SECURE_SSL_REDIRECT=False # True to force HTTP→HTTPS redirects (behind a TLS-terminating proxy)

# ======================= AI assist (optional) =======================
# OpenAI-compatible seam — Groq by default. The feature degrades gracefully to a
# keyword heuristic when LLM_API_KEY is empty, so the app runs fine without it.
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=                     # free Groq key (gsk_...) from https://console.groq.com
LLM_CLASSIFIER_MODEL=llama-3.1-8b-instant
LLM_GENERATOR_MODEL=llama-3.3-70b-versatile

# ======================= Frontend (Next.js) =======================
# Browser-side base URL for the API
NEXT_PUBLIC_API_URL=http://localhost:8000/api
# Server-side (route handlers / SSR) API base — internal host in Docker
API_URL=http://localhost:8000/api
